{
  "name": "litch-rpg-webapp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:web\"",
    "dev:web": "vite --host 0.0.0.0 --port 5173",
    "dev:server": "tsx watch src/server/index.ts",
    "build": "tsc -p tsconfig.server.json --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "start": "tsx src/server/index.ts",
    "start:server": "tsx src/server/index.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "mysql2": "^3.22.4",
    "nodemailer": "^8.0.9",
    "posthog-node": "^5.35.13",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.12.4",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "concurrently": "^9.1.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-pwa": "^1.3.0"
  }
}
